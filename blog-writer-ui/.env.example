# Framer Configuration
FRAMER_PROJECT_URL=
FRAMER_API_KEY=
FRAMER_BLOG_COLLECTION=Services

# Google Gemini (AI chat + images) — add in Vercel Project Settings → Environment Variables
# Use a key with NO "HTTP referrers" restriction; server-side API routes send an empty referer.
GEMINI_API_KEY=

# Optional: Vertex AI instead of GEMINI_API_KEY (service account JSON + project id)
# GOOGLE_APPLICATION_CREDENTIALS_JSON=
# GOOGLE_CLOUD_PROJECT=

# Authentication
AUTH_PASSWORD=
SESSION_SECRET=
